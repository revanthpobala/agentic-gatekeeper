{
  "name": "agentic-gatekeeper",
  "displayName": "agentic-gatekeeper",
  "description": "A VS Code extension to validate and apply Markdown instructions to staged code via an AI Agent.",
  "version": "0.1.3",
  "publisher": "revanth",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/revanth/agentic-gatekeeper.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentic-gatekeeper.analyzeStaged",
        "title": "Agentic Gatekeeper: Analyze Staged Changes",
        "icon": "$(hubot)"
      },
      {
        "command": "agentic-gatekeeper.configureApiKey",
        "title": "Agentic Gatekeeper: Configure API Key"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "agentic-gatekeeper.analyzeStaged",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Agentic Gatekeeper",
      "properties": {
        "agenticGatekeeper.aiProvider": {
          "type": "string",
          "enum": [
            "Gemini",
            "OpenAI",
            "Anthropic",
            "OpenRouter",
            "Custom (Ollama/Local)",
            "Native IDE"
          ],
          "default": "Native IDE",
          "description": "Select the primary AI provider to use for gatekeeping."
        },
        "agenticGatekeeper.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Google Gemini API Key."
        },
        "agenticGatekeeper.geminiModel": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "The Gemini model to use."
        },
        "agenticGatekeeper.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "Your OpenAI API Key."
        },
        "agenticGatekeeper.openaiModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "The OpenAI model to use."
        },
        "agenticGatekeeper.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Anthropic API Key (for Claude models)."
        },
        "agenticGatekeeper.anthropicModel": {
          "type": "string",
          "default": "claude-3-7-sonnet-20250219",
          "description": "The Anthropic model to use."
        },
        "agenticGatekeeper.openRouterApiKey": {
          "type": "string",
          "default": "",
          "description": "Your OpenRouter API Key (for DeepSeek, Meta, etc.)."
        },
        "agenticGatekeeper.openRouterModel": {
          "type": "string",
          "default": "deepseek/deepseek-coder",
          "description": "The OpenRouter model string (e.g., 'deepseek/deepseek-chat', 'anthropic/claude-3-haiku')."
        },
        "agenticGatekeeper.openRouterReferer": {
          "type": "string",
          "default": "https://github.com/yourusername/yourproject",
          "description": "Optional: Your app URL (HTTP-Referer) for OpenRouter rankings."
        },
        "agenticGatekeeper.openRouterTitle": {
          "type": "string",
          "default": "Agentic Gatekeeper Client",
          "description": "Optional: Your app title (X-Title) for OpenRouter rankings."
        },
        "agenticGatekeeper.customBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "The Base URL for a custom OpenAI-compatible API (e.g., Ollama, LM Studio)."
        },
        "agenticGatekeeper.customModel": {
          "type": "string",
          "default": "llama3",
          "description": "The Model ID for your custom API."
        },
        "agenticGatekeeper.customApiKey": {
          "type": "string",
          "default": "lm-studio",
          "description": "The API Key for your custom API (often 'lm-studio' or 'ollama' for local servers)."
        },
        "agenticGatekeeper.rulesFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".gatekeeper/*.md",
            "**/*-gatekeeper.md",
            "**/*-instructions.md",
            "AGENTS.md",
            "CONTRIBUTING.md",
            "ARCHITECTURE.md"
          ],
          "description": "Glob patterns for Markdown instruction files the Gatekeeper should enforce. Supports wildcards (e.g., 'docs/rules/*.md')."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/minimatch": "^5.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@vscode/extension-telemetry": "^1.5.0",
    "@vscode/prompt-tsx": "^0.4.0-alpha.7",
    "minimatch": "^10.2.2",
    "openai": "^6.22.0",
    "simple-git": "^3.31.1"
  }
}